      "source": [
        "# Create a 'Date' column from 'Year', 'Month', and 'Day'\n",
        "# Handle potential errors during date conversion by coercing invalid dates to NaT\n",
        "df['Date'] = pd.to_datetime(df[['Year', 'Month', 'Day']], errors='coerce')\n",
        "\n",
        "# Drop rows where 'Date' could not be parsed (e.g., due to missing Month/Day)\n",
        "df.dropna(subset=['Date'], inplace=True)\n",
        "\n",
        "# Sort the DataFrame by 'Date' to ensure the line chart is plotted correctly\n",
        "df.sort_values('Date', inplace=True)\n",
        "\n",
        "# Plot the line chart\n",
        "plt.figure(figsize=(14, 7))\n",
        "sns.lineplot(x='Date', y='Precipitation', data=df)\n",
        "plt.title('Rainfall (Precipitation) Over Time')\n",
        "plt.xlabel('Date')\n",
        "plt.ylabel('Precipitation')\n",
        "plt.grid(True)\n",
        "plt.tight_layout()\n",
        "plt.show()"
